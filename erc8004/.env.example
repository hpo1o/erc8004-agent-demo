# ── Pinata IPFS ───────────────────────────────────────────────────────────────
# JWT token for uploading registration files to IPFS via Pinata.
# Get it at: https://app.pinata.cloud/developers/api-keys
# Required permission: pinning (pinJSONToIPFS)
PINATA_JWT=eyJhbGci...

# ── Signer wallet ─────────────────────────────────────────────────────────────
# Private key of the wallet that will own the agent NFTs (ERC-721 tokens).
# This wallet must have ETH on Base Sepolia for gas.
# Get testnet ETH: https://www.alchemy.com/faucets/base-sepolia
#
# IMPORTANT: Must be DIFFERENT from image-generator PAYER_PRIVATE_KEY.
# Same wallet = Reputation Registry will be skipped (ERC-8004 rule:
# the contract rejects self-feedback where caller == agent owner).
# Format: 0x + 64 hex chars.
ERC8004_PRIVATE_KEY=0x...

# ── RPC ───────────────────────────────────────────────────────────────────────
# Base Sepolia RPC URL. The public endpoint below works but may be rate-limited.
# For production use an Alchemy / Infura / QuickNode key.
BASE_SEPOLIA_RPC=https://sepolia.base.org
