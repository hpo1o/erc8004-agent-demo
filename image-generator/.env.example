# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key for DALL-E 2 image generation.
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── x402 payment ──────────────────────────────────────────────────────────────
# Private key of the wallet that pays colorizer-service $0.01 USDC per call.
# Must have ETH (gas) and USDC on Base Sepolia.
# Format: 0x + 64 hex chars.
# Get testnet ETH  : https://www.alchemy.com/faucets/base-sepolia
# Get testnet USDC : https://faucet.circle.com  (select Base Sepolia)
PAYER_PRIVATE_KEY=0x...

# ── colorizer-service ─────────────────────────────────────────────────────────
# A2A endpoint of the colorizer-service agent.
# Default (local dev): http://localhost:3000/agent
COLORIZER_URL=http://localhost:3000/agent

# ── ERC-8004 reputation (optional) ───────────────────────────────────────────
# These are only needed for on-chain reputation recording after each call.
# If any of these are missing the feedback step is skipped silently —
# the main flow (generate + colorize + save output.jpg) always completes.

# Pinata JWT for uploading the off-chain feedback file to IPFS.
# Get it at: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=eyJhbGci...

# Private key used to sign the giveFeedback() transaction.
# Can be the same key as PAYER_PRIVATE_KEY — the payer is the natural
# source of feedback since they interacted with the agent.
ERC8004_PRIVATE_KEY=0x...

# Base Sepolia RPC URL. The public endpoint works but may be rate-limited.
# For reliable use: get a free key from https://www.alchemy.com
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Address that receives USDC payments (set in colorizer-service/.env).
# Used in the proofOfPayment field of the off-chain feedback JSON.
PAYMENT_RECIPIENT_ADDRESS=0x...
