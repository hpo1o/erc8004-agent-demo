# Note: No OPENAI_API_KEY needed — Agent 2 uses deterministic
# image processing (sharp.grayscale()) without any LLM.

# x402 payment recipient — your wallet address on Base Sepolia
# This address receives USDC when a client pays for colorization
PAYMENT_RECIPIENT_ADDRESS=0x...

# x402 facilitator — defaults to Agently's hosted service, override if self-hosting
# X402_FACILITATOR_URL=https://facilitator.agently.com

# ERC-8004 on-chain registration
# Private key of the wallet used to sign the register transaction (Base Sepolia)
# Never commit this to git
ERC8004_PRIVATE_KEY=0x...
