# colorizer-service — Railway environment variables
# Set these in Railway dashboard: Service → Variables

# Wallet that receives x402 payments (your MetaMask address)
PAYMENT_RECIPIENT_ADDRESS=0xYourAddress

# x402 facilitator: false = Coinbase (https://x402.org/facilitator)
X402_MOCK=false

# Base Sepolia RPC (public endpoint, or use Alchemy/Infura for reliability)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Private key of the agent owner wallet (for ERC-8004 on-chain ops)
ERC8004_PRIVATE_KEY=0x...

# Note: OPENAI_API_KEY is NOT needed — Agent 2 (colorizer) has no LLM calls
