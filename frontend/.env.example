# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key for DALL-E 2 image generation.
OPENAI_API_KEY=sk-...

# ── x402 payment ──────────────────────────────────────────────────────────────
# Private key of the wallet that pays colorizer-service $0.01 USDC per call.
# Must have ETH (gas) and USDC on Base Sepolia.
PAYER_PRIVATE_KEY=0x...

# ── ERC-8004 ───────────────────────────────────────────────────────────────────
# Private key for signing reputation/validation transactions.
# Can be the same as PAYER_PRIVATE_KEY (reputation step will be skipped if so).
ERC8004_PRIVATE_KEY=0x...

# Pinata JWT for uploading off-chain files to IPFS (optional).
# Reputation and validation steps are skipped silently if absent.
PINATA_JWT=eyJ...

# Base Sepolia RPC (optional — defaults to https://sepolia.base.org)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Only needed for local dev.
PORT=3001
